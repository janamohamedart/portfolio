#include <iostream>
#include <string>
using namespace std;

class Student {
private:
    string name;
    int age;

public:
    void setname(string n) {
        name = n;
    }

    string getname() {
        return name;
    }

    void setage(int a) {
        age = a;
    }

    int getage() {
        return age;
    }
};

int main() {
    Student s1;

    s1.setname("Ahmed");
    s1.setage(18);

    cout << "The name is: " << s1.getname() << endl;
    cout << "The age is: " << s1.getage() << endl;

    return 0;
}
